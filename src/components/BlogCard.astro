---
import { withBase } from "../utils/paths";

type Props = {
  href: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
  tags: string[];
};

const { href, title, excerpt, date, category, tags } = Astro.props;
---

<article class="post-preview">
  <div class="card-meta">
    <span>{category}</span>
    <span>{date}</span>
  </div>
  <h3><a href={withBase(href)}>{title}</a></h3>
  <p>{excerpt}</p>
  <div class="tag-list">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</article>
