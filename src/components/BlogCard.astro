---
import { withBase } from "../utils/paths";

type Props = {
  href: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
};

const { href, title, excerpt, date, category } = Astro.props;
---

<article class="post-preview" data-post-card data-category={category.toLowerCase()} data-search={`${title} ${excerpt} ${category}`.toLowerCase()}>
  <div class="card-meta">
    <span>{category}</span>
    <span>{date}</span>
  </div>
  <h3><a href={withBase(href)}>{title}</a></h3>
  <p>{excerpt}</p>
</article>
