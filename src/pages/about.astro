---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="About"
  description="About Ian Portal."
>
  <PageHero
    title="About"
    description="留一些之後還會回來看的東西。"
  />

  <section class="section">
    <div class="container simple-copy">
      <p>這裡會放工具、筆記、攻略與整理文。</p>
      <ul>
        <li>學習筆記</li>
        <li>遊戲攻略</li>
        <li>旅行工具</li>
        <li>分類與標籤整理</li>
      </ul>
    </div>
  </section>
</BaseLayout>
