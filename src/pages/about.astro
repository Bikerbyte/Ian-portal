---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="About"
  description="About Ian Portal."
>
  <PageHero
    title="About"
    description="Notes, tools, route logs, and whatever is still useful later."
  />

  <section class="section">
    <div class="container simple-copy">
      <p>Mostly Astro, Markdown, and small front-end tools.</p>
      <ul>
        <li>study notes</li>
        <li>game guides</li>
        <li>travel tools</li>
        <li>tag archives</li>
      </ul>
    </div>
  </section>
</BaseLayout>
