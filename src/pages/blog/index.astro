---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import BlogCard from "../../components/BlogCard.astro";
import { termSlug } from "../../utils/content";
import { withBase } from "../../utils/paths";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categories = [...new Set(posts.map((post) => post.data.category))];
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Blog" description="Game guides, study notes, and practical writing collected in Ian Portal.">
  <PageHero
    title="Blog"
    description="文章、分類、標籤。"
  />

  <section class="section">
    <div class="container">
      <div class="archive-block">
        <span class="archive-label">分類</span>
        <div class="archive-strip">
          {categories.map((category) => (
            <a class="tag-button" href={withBase(`/categories/${termSlug(category)}/`)}>{category}</a>
          ))}
        </div>
      </div>

      <div class="archive-block">
        <span class="archive-label">標籤</span>
        <div class="archive-strip">
          {tags.map((tag) => (
            <a class="tag-button" href={withBase(`/tags/${termSlug(tag)}/`)}>{tag}</a>
          ))}
        </div>
      </div>

      <div class="list-stack">
        {posts.map((post) => (
          <BlogCard
            href={`/blog/${post.id.replace(/\.md$/, "")}/`}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
