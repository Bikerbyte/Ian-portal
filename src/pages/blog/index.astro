---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categories = [...new Set(posts.map((post) => post.data.category))];
---

<BaseLayout title="文章" description="文章分類與標籤整理。">
  <PageHero title="文章" description="搜尋或依分類查看文章。" />

  <section class="section">
    <div class="container">
      <div class="blog-controls">
        <label class="search-field">
          <span class="archive-label">搜尋</span>
          <input type="search" placeholder="搜尋標題或摘要" data-search-input />
        </label>

        <label class="select-field">
          <span class="archive-label">分類</span>
          <select data-category-filter>
            <option value="">全部</option>
            {categories.map((category) => (
              <option value={category.toLowerCase()}>{category}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="search-summary" data-search-summary>
        共 {posts.length} 篇文章
      </div>

      <div class="list-stack" data-post-list>
        {posts.map((post) => (
          <BlogCard
            href={`/blog/${post.id.replace(/\.md$/, "")}/`}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date.toLocaleDateString("zh-TW", { year: "numeric", month: "short", day: "numeric" })}
            category={post.data.category}
          />
        ))}
      </div>

      <p class="search-empty" data-search-empty hidden>找不到符合條件的文章。</p>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.querySelector("[data-search-input]");
  const categoryFilter = document.querySelector("[data-category-filter]");
  const postCards = Array.from(document.querySelectorAll("[data-post-card]"));
  const summary = document.querySelector("[data-search-summary]");
  const empty = document.querySelector("[data-search-empty]");

  function applyFilters() {
    const keyword = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
    const category = categoryFilter instanceof HTMLSelectElement ? categoryFilter.value : "";
    let visibleCount = 0;

    postCards.forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const matchesKeyword = !keyword || card.dataset.search?.includes(keyword);
      const matchesCategory = !category || card.dataset.category === category;
      const visible = Boolean(matchesKeyword && matchesCategory);

      card.hidden = !visible;
      if (visible) {
        visibleCount += 1;
      }
    });

    if (summary instanceof HTMLElement) {
      summary.textContent = keyword || category ? `找到 ${visibleCount} 篇文章` : `共 ${postCards.length} 篇文章`;
    }

    if (empty instanceof HTMLElement) {
      empty.hidden = visibleCount > 0;
    }
  }

  searchInput?.addEventListener("input", applyFilters);
  categoryFilter?.addEventListener("change", applyFilters);
</script>
