---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../utils/paths";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const allPosts = (await getCollection("blog")).sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const index = allPosts.findIndex((entry) => entry.id === post.id);
const previousPost = index > 0 ? allPosts[index - 1] : null;
const nextPost = index >= 0 && index < allPosts.length - 1 ? allPosts[index + 1] : null;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <section class="section post-section">
    <div class="container post-layout">
      <article class="post-article">
        <div class="post-meta">
          <span>{post.data.category}</span>
          <span>{post.data.date.toLocaleDateString("zh-TW", { year: "numeric", month: "long", day: "numeric" })}</span>
          <span>{Math.max(3, Math.ceil(post.body.split(/\s+/).length / 180))} 分鐘</span>
        </div>
        <h1>{post.data.title}</h1>
        <div class="post-content">
          <Content />
        </div>
      </article>

      <aside class="post-sidebar">
        {tocHeadings.length > 0 && (
          <nav class="sidebar-card toc-card" aria-label="文章目錄">
            <p class="sidebar-title">文章目錄</p>
            <div class="toc-links">
              {tocHeadings.map((heading) => (
                <a class:list={[`toc-depth-${heading.depth}`]} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              ))}
            </div>
          </nav>
        )}

        <div class="sidebar-card">
          {previousPost && <a href={withBase(`/blog/${previousPost.id.replace(/\.md$/, "")}/`)}>上一篇：{previousPost.data.title}</a>}
          {nextPost && <a href={withBase(`/blog/${nextPost.id.replace(/\.md$/, "")}/`)}>下一篇：{nextPost.data.title}</a>}
          <a href={withBase("/blog/")}>回文章列表</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
