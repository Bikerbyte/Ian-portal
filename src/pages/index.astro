---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import { withBase } from "../utils/paths";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);
---

<BaseLayout title="首頁" description={site.description}>
  <PageHero
    title="Ian Portal"
    description="放一些自己之後還會回來看的內容。"
    ctas={[
      { href: "/blog/", label: "看文章" },
      { href: "/tools/packing-list/", label: "看工具", kind: "secondary" }
    ]}
  />

  <section class="section">
    <div class="container">
      <div class="home-intro">
        <p>{site.tagline}</p>
      </div>
      <div class="home-links">
        <a href={withBase("/projects/")}>Packing List Generator</a>
        <a href={withBase("/blog/")}>文章列表</a>
        <a href={withBase("/tags/demo/")}>Demo 標籤</a>
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>最新文章</h2>
        </div>
      </div>
      <div class="list-stack">
        {recentPosts.map((post) => (
          <BlogCard
            href={`/blog/${post.id.replace(/\.md$/, "")}/`}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date.toLocaleDateString("zh-TW", { year: "numeric", month: "short", day: "numeric" })}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>工具</h2>
        </div>
      </div>
      <div class="list-stack">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

