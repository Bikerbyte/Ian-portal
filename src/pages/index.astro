---
import { getCollection } from "astro:content";
import { readdirSync } from "node:fs";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { withBase } from "../utils/paths";
import { isPublicTag, termSlug } from "../utils/content";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);
const allPublicTags = [...new Set(posts.flatMap((post) => post.data.tags).filter(isPublicTag))];
const seriesCount = new Set(posts.map((post) => post.data.series).filter(Boolean)).size;
const startLinks = [
  {
    href: "/tags/aws/",
    icon: "cloud",
    eyebrow: "Cloud",
    title: "雲端筆記",
    description: "AWS、EC2、RAG 部署與基礎操作。",
    tags: ["AWS", "EC2", "RAG"]
  },
  {
    href: "/tags/iac/",
    icon: "lab",
    eyebrow: "Lab",
    title: "IaC Lab",
    description: "Terraform、Ansible 與可重複建立的實作紀錄。",
    tags: ["Terraform", "Ansible", "Docker"]
  },
  {
    href: "/tags/observability/",
    icon: "chart",
    eyebrow: "Ops",
    title: "Observability",
    description: "監控、Grafana 與系統觀測的學習筆記。",
    tags: ["Grafana", "Monitoring"]
  },
  {
    href: "/blog/",
    icon: "document",
    eyebrow: "Index",
    title: "全部文章",
    description: "用搜尋、分類和標籤快速找到想看的內容。",
    tags: ["搜尋", "分類", "標籤"]
  }
];
const startIcons: Record<string, string> = {
  cloud: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M16.5 35.5h18a8 8 0 0 0 .9-15.95A12 12 0 0 0 12.3 17.9 9 9 0 0 0 16.5 35.5Z"/></svg>`,
  lab: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="m13 15 11-6 11 6-11 6-11-6Z"/><path d="M13 15v13l11 6 11-6V15"/><path d="M24 21v13"/><path d="M31 31.5a7.5 7.5 0 1 0 15 0 7.5 7.5 0 0 0-15 0Z"/><path d="m36 31.5 3 3 5-6"/></svg>`,
  chart: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M9 10h30v28H9z"/><path d="M15 31 22 24l5 5 8-12"/><path d="M15 16h4"/><path d="M15 38v-5"/><path d="M39 38h-5"/></svg>`,
  document: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M13 7h15l7 7v27H13z"/><path d="M28 7v8h7"/><path d="M18 23h12"/><path d="M18 30h12"/><path d="M18 36h8"/></svg>`
};
type HeroImage = {
  src: string;
  alt: string;
};
const heroImages: HeroImage[] = readdirSync(new URL("../../public/images/", import.meta.url))
  .filter((fileName) => /^home-[\w-]+\.(?:avif|webp|png|jpe?g)$/i.test(fileName))
  .sort((a, b) => a.localeCompare(b, "en", { numeric: true }))
  .map((fileName) => ({
    src: `/images/${fileName}`,
    alt: fileName
      .replace(/\.[^.]+$/, "")
      .replace(/^home-/, "")
      .replace(/[-_]+/g, " ")
  }));
---

<BaseLayout title="首頁" description={site.description}>
  <section class="home-hero section">
    <div class="container home-hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Ian Notes / Dev Notes</p>
        <h1>Ian's Blog</h1>
        <p class="hero-description">
          Hi~ 歡迎來到我的個人網站，這裡放一些學習筆記、專案和生活紀錄。
        </p>
        <div class="hero-actions">
          <a class="button" href={withBase("/blog/")}>開始閱讀</a>
          <a class="button button-secondary" href={withBase("/projects/")}>查看專案</a>
        </div>
        <div class="hero-stats" aria-label="網站內容統計">
          <span>{posts.length} 篇文章</span>
          <span>{allPublicTags.length} 個標籤</span>
          <span>{seriesCount} 個系列</span>
        </div>
      </div>

      <div class="hero-slideshow" aria-label="首頁照片輪播">
        {heroImages.map((image, index) => (
          <figure class:list={["hero-slide", index === 0 && "is-active"]}>
            <img src={withBase(image.src)} alt={image.alt} loading={index === 0 ? "eager" : "lazy"} />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section home-start-section">
    <div class="container">
      <div class="section-header home-section-header">
        <div>
          <p class="archive-label">Start Here</p>
          <h2>從這裡開始</h2>
        </div>
      </div>
      <div class="home-start-grid">
        {startLinks.map((item) => (
          <a class="home-start-card" href={withBase(item.href)}>
            <span class:list={["home-start-icon", `home-start-icon-${item.icon}`]} set:html={startIcons[item.icon]} />
            <span class="home-start-body">
              <span class="home-start-eyebrow">{item.eyebrow}</span>
              <strong>{item.title}</strong>
              <span>{item.description}</span>
              <span class="home-start-tags">
                {item.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </span>
            </span>
            <span class="home-start-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="m9 5 7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tinted">
    <div class="container home-content-grid">
      <div class="home-latest-column">
        <div class="section-header home-section-header">
          <div>
            <p class="archive-label">Latest Notes</p>
            <h2>最近文章</h2>
          </div>
          <a class="inline-link" href={withBase("/blog/")}>全部文章</a>
        </div>
        <div class="home-latest-list">
          {recentPosts.map((post) => (
            <article class="home-latest-row">
              <div class="home-latest-copy">
                <div class="card-meta">
                  <a href={withBase(`/categories/${termSlug(post.data.category)}/`)}>{post.data.category}</a>
                  <span>{post.data.date.toLocaleDateString("zh-TW", { year: "numeric", month: "short", day: "numeric" })}</span>
                </div>
                <h3>
                  <a href={withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)}>{post.data.title}</a>
                </h3>
              </div>
              <div class="home-latest-actions">
                <div class="tag-list home-latest-tags">
                  {post.data.tags.filter(isPublicTag).slice(0, 5).map((tag) => (
                    <a class="tag" href={withBase(`/tags/${termSlug(tag)}/`)}>{tag}</a>
                  ))}
                </div>
                <a class="read-link" href={withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)}>
                  閱讀文章
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const heroSlides = Array.from(document.querySelectorAll(".hero-slideshow .hero-slide"));
  let activeHeroSlide = 0;

  if (heroSlides.length > 1) {
    window.setInterval(() => {
      heroSlides[activeHeroSlide]?.classList.remove("is-active");
      activeHeroSlide = (activeHeroSlide + 1) % heroSlides.length;
      heroSlides[activeHeroSlide]?.classList.add("is-active");
    }, 5000);
  }
</script>
