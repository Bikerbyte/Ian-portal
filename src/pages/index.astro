---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
import { withBase } from "../utils/paths";
import { termSlug } from "../utils/content";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 2);
const categories = [...new Set(posts.map((post) => post.data.category))];
---

<BaseLayout title="Home" description={site.description}>
  <PageHero
    title="Ian Portal"
    description={site.tagline}
    ctas={[
      { href: "/blog/", label: "Blog" },
      { href: "/tools/packing-list/", label: "Packing List", kind: "secondary" }
    ]}
  />

  <section class="section">
    <div class="container">
      <div class="archive-strip">
        <span class="archive-label">Browse</span>
        <a class="tag-button" href={withBase("/projects/")}>Projects</a>
        {categories.map((category) => (
          <a class="tag-button" href={withBase(`/categories/${termSlug(category)}/`)}>{category}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Recent posts</h2>
        </div>
      </div>
      <div class="list-stack">
        {recentPosts.map((post) => (
          <BlogCard
            href={`/blog/${post.id.replace(/\.md$/, "")}/`}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Projects</h2>
        </div>
      </div>
      <div class="list-stack">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
