---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Projects" description="Projects, tools, experiments, and guides collected in Ian Portal.">
  <PageHero
    eyebrow="Projects"
    title="Tools and experiments with clear entry points."
    description="The first version stays intentionally focused. Each card below points to something usable, readable, or extendable instead of a placeholder shelf."
  />

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

